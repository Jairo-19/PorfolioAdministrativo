---
const contacto = {
  correo: "ramosj06jairo@gmail.com",
  telefono: "722408527",
};

const redesSociales = [
  {
    nombre: "GitHub",
    url: "https://github.com/Jairo-19",
    icono: "github",
    color: "#333333",
  },
  {
    nombre: "LinkedIn",
    url: "https://www.linkedin.com/in/jairo-jimenez-ramos-728463258/",
    icono: "linkedin",
    color: "#0A66C2",
  },
];
---

<section id="contacto" class="py-24 px-8 md:px-20 bg-gray-50">

  <!-- Título de sección -->
  <h2 class="scroll-hidden text-4xl font-bold text-gray-900 text-center mb-8" style="font-family: 'Playfair Display', serif">
    ¿Hablamos? <span class="text-[#cc0247]">Contacta conmigo</span>
  </h2>

  <p class="scroll-hidden scroll-delay-1 text-gray-600 text-center max-w-2xl mx-auto mb-16 text-lg leading-relaxed">
    Siempre estoy abierto a nuevas oportunidades y colaboraciones. No dudes en contactarme a través de mis redes o directamente por correo o teléfono.
  </p>

  <!-- Grid de contacto -->
  <div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-4xl mx-auto mb-16">
    
    <!-- Correo -->
    <div class="scroll-hidden scroll-delay-2 bg-white rounded-2xl p-8 shadow-sm border border-gray-100 text-center hover:shadow-md hover:-translate-y-1 transition-all duration-300">
      <div class="w-12 h-12 mx-auto mb-4 flex items-center justify-center bg-red-50 rounded-lg">
        <svg class="w-6 h-6 text-[#cc0247]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
        </svg>
      </div>
      <h3 class="text-lg font-semibold text-gray-900 mb-2">Correo</h3>
      <a href={`mailto:${contacto.correo}`} class="text-gray-600 hover:text-[#cc0247] transition-colors duration-200 break-all">
        {contacto.correo}
      </a>
    </div>

    <!-- Teléfono -->
    <div class="scroll-hidden scroll-delay-3 bg-white rounded-2xl p-8 shadow-sm border border-gray-100 text-center hover:shadow-md hover:-translate-y-1 transition-all duration-300">
      <div class="w-12 h-12 mx-auto mb-4 flex items-center justify-center bg-red-50 rounded-lg">
        <svg class="w-6 h-6 text-[#cc0247]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
        </svg>
      </div>
      <h3 class="text-lg font-semibold text-gray-900 mb-2">Teléfono</h3>
      <a href={`tel:${contacto.telefono}`} class="text-gray-600 hover:text-[#cc0247] transition-colors duration-200">
        {contacto.telefono}
      </a>
    </div>

    <!-- Disponibilidad -->
    <div class="scroll-hidden scroll-delay-4 bg-white rounded-2xl p-8 shadow-sm border border-gray-100 text-center hover:shadow-md hover:-translate-y-1 transition-all duration-300">
      <div class="w-12 h-12 mx-auto mb-4 flex items-center justify-center bg-red-50 rounded-lg">
        <svg class="w-6 h-6 text-[#cc0247]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
      </div>
      <h3 class="text-lg font-semibold text-gray-900 mb-2">Disponibilidad</h3>
      <p class="text-gray-600">
        Disponible para nuevos proyectos
      </p>
    </div>

  </div>

  <!-- Redes sociales -->
  <div class="scroll-hidden scroll-delay-2 text-center">
    <h3 class="text-lg font-semibold text-gray-900 mb-6">Sígueme en mis redes</h3>
    <div class="flex justify-center gap-6 flex-wrap">
      {redesSociales.map(({ nombre, url, icono }) => (
        <a
          href={url}
          target="_blank"
          rel="noopener noreferrer"
          title={nombre}
          class="w-14 h-14 flex items-center justify-center rounded-full border-2 border-gray-200 hover:border-[#cc0247] hover:bg-red-50 transition-all duration-300 group"
        >
          {icono === "github" && (
            <svg class="w-6 h-6 text-gray-700 group-hover:text-[#cc0247] transition-colors" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v 3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z" />
            </svg>
          )}
          {icono === "linkedin" && (
            <svg class="w-6 h-6 text-gray-700 group-hover:text-[#cc0247] transition-colors" fill="currentColor" viewBox="0 0 24 24">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.225 0z" />
            </svg>
          )}
        </a>
      ))}
    </div>
  </div>

</section>

<script>
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('scroll-visible');
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.1 }
  );

  document.querySelectorAll('#contacto .scroll-hidden').forEach((el) => {
    observer.observe(el);
  });
</script>
