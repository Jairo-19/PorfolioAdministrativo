---
---

<section id="inicio" class="min-h-screen flex flex-col-reverse md:flex-row items-center px-8 md:px-20 pt-28 md:pt-20 pb-12 gap-10 md:gap-12">

  <!-- Contenedor de texto -->
  <div class="flex-1 flex flex-col gap-6 text-center md:text-left">
    <h1 class="anim-slide-up text-5xl md:text-6xl font-bold text-gray-900 leading-tight" style="animation-delay: 0.1s">
      Hola, soy <span class="text-[#cc0247]">Jairo Jiménez Ramos</span>
    </h1>
    <p class="anim-slide-up text-lg text-gray-600 max-w-xl leading-relaxed" style="animation-delay: 0.3s">
      <span id="typewriter-text"></span><span id="typewriter-cursor" class="inline-block w-0.5 h-5 bg-[#cc0247] ml-0.5 align-middle">&#8203;</span>
    </p>
    <div class="anim-slide-up flex gap-4 mt-2 justify-center md:justify-start" style="animation-delay: 0.5s">
      <a href="#proyectos" class="bg-[#cc0247] text-white px-6 py-3 rounded-lg font-medium hover:bg-[#a8013b] transition-colors duration-300">
        Ver proyectos
      </a>
      <a href="#contacto" class="border border-gray-300 text-gray-700 px-6 py-3 rounded-lg font-medium hover:border-[#cc0247] hover:text-[#cc0247] transition-colors duration-300">
        Contacto
      </a>
    </div>
  </div>

  <!-- Contenedor de imagen -->
  <div class="anim-slide-right flex-1 flex justify-center items-center" style="animation-delay: 0.3s">
    <div class="w-48 h-48 sm:w-64 sm:h-64 md:w-96 md:h-96 rounded-full overflow-hidden border-4 border-[#cc0247] shadow-lg">
      <img src="/provisional.webp" alt="Jairo Jiménez" class="w-full h-full object-cover" />
    </div>
  </div>

</section>

<script>
  const texto = "Desarrollador web apasionado por crear experiencias digitales modernas, limpias y funcionales. Aquí encontrarás mis proyectos, habilidades y todo sobre mi trayectoria profesional.";
  const target  = document.getElementById('typewriter-text')!;
  const cursor  = document.getElementById('typewriter-cursor')!;
  const delay   = 800;   // ms antes de empezar (tras la animación del título)
  const speed   = 28;    // ms por carácter

  let i = 0;
  setTimeout(() => {
    const interval = setInterval(() => {
      target.textContent += texto[i];
      i++;
      if (i >= texto.length) {
        clearInterval(interval);
        setTimeout(() => cursor.classList.add('done'), 1200);
      }
    }, speed);
  }, delay);
</script>

