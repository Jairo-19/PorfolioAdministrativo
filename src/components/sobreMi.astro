---

<section id="sobre-mi" class="py-24 px-8 md:px-20 bg-gray-50">

  <!-- Título de sección -->
  <h1 class="sm-titulo text-4xl font-bold text-gray-900 text-center mb-16" style="font-family: 'Playfair Display', serif">
    Sobre <span class="text-[#9E5842]">mí</span>
  </h1>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-5xl mx-auto">

    <!-- ── Quién soy (ancho completo, 3 columnas internas) ── -->
    <div class="sm-card-principal relative bg-white rounded-2xl p-8 shadow-sm border border-gray-100 md:col-span-2 border-t-4 border-t-[#9E5842]">
      <span class="chincheta chincheta-der" aria-hidden="true"><svg width="16" height="24" viewBox="0 0 16 24" xmlns="http://www.w3.org/2000/svg"><circle cx="8" cy="8" r="7" fill="#d94f82"/><circle cx="8" cy="7" r="6" fill="#ff78a6"/><circle cx="5.5" cy="4.5" r="2.5" fill="#ffb3cc" opacity="0.5"/><rect x="7" y="14" width="2" height="10" rx="1" fill="#aaa"/></svg></span>
      <h3 class="text-xl font-semibold text-gray-900 mb-6 flex items-center gap-2">
        <span class="text-[#9E5842]">01.</span> ¿Quién soy?
      </h3>

      <!-- Párrafo completo -->
      <p class="text-gray-600 leading-relaxed mb-8">
        Soy desarrollador web con experiencia tanto en backend como en frontend,
        aunque donde realmente disfruto es dando forma a interfaces. Me gusta que
        lo que se ve en pantalla sea claro, rápido e intuitivo. Me fijo mucho en
        los detalles de diseño y disfruto creando experiencias que resulten
        cómodas y naturales para el usuario.
      </p>

      <!-- 2 columnas: info+estudios | idiomas -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">

        <!-- Información personal + Estudios -->
        <div class="flex flex-col gap-6">
          <div>
            <h4 class="text-xs font-bold text-gray-900 uppercase tracking-widest mb-3 border-b-2 border-[#9E5842] pb-2">Información personal</h4>
            <ul class="flex flex-col gap-2">
              {infoPersonal.map(({ etiqueta, valor }) => (
                <li class="flex justify-between text-sm">
                  <span class="text-gray-400">{etiqueta}</span>
                  <span class="text-gray-700 font-medium">{valor}</span>
                </li>
              ))}
            </ul>
          </div>
          <div>
            <h4 class="text-xs font-bold text-gray-900 uppercase tracking-widest mb-3 border-b-2 border-[#9E5842] pb-2">Formación académica</h4>
            <ul class="flex flex-col gap-3 mb-6">
              {estudios.map(({ titulo, centro, anio }) => (
                <li>
                  <p class="text-gray-700 font-medium text-sm">{titulo}</p>
                  <p class="text-gray-400 text-xs">{centro} &middot; {anio}</p>
                </li>
              ))}
            </ul>
            <h4 class="text-xs font-bold text-gray-900 uppercase tracking-widest mb-3 border-b-2 border-[#9E5842] pb-2">Cursos complementarios</h4>
            <ul class="flex flex-col gap-2">
              {cursos.map(({ titulo, plataforma }) => (
                <li>
                  <p class="text-gray-700 font-medium text-sm">{titulo}</p>
                  <p class="text-gray-400 text-xs">{plataforma}</p>
                </li>
              ))}
            </ul>
          </div>
        </div>

        <!-- Habilidades + Idiomas -->
        <div class="flex flex-col gap-6">
          <div>
            <h4 class="text-xs font-bold text-gray-900 uppercase tracking-widest mb-3 border-b-2 border-[#9E5842] pb-2">Habilidades</h4>
            <ul class="flex flex-wrap gap-2">
              {habilidades.map((h) => (
                <li class="bg-gray-50 border border-gray-200 text-gray-700 text-xs font-medium px-3 py-1.5 rounded-lg">
                  {h}
                </li>
              ))}
            </ul>
          </div>
          <div>
            <h4 class="text-xs font-bold text-gray-900 uppercase tracking-widest mb-3 border-b-2 border-[#9E5842] pb-2">Idiomas</h4>
            <ul class="flex flex-col gap-5">
              {idiomas.map(({ nombre, nivel, porcentaje }) => (
                <li>
                  <div class="flex justify-between mb-1">
                    <span class="text-gray-700 font-medium text-sm">{nombre}</span>
                    <span class="text-xs text-gray-400">{nivel}</span>
                  </div>
                  <div class="w-full bg-gray-100 rounded-full h-2">
                    <div
                      class="bg-[#9E5842] h-2 rounded-full transition-all duration-700"
                      style={`width: ${porcentaje}%`}
                    />
                  </div>
                </li>
              ))}
            </ul>
          </div>
        </div>

      </div>
    </div>

    <!-- ── Experiencia ── -->
    <div class="sm-card-full relative bg-white rounded-2xl p-8 shadow-sm border border-gray-100 md:col-span-2 border-t-4 border-t-[#9E5842]">
      <span class="chincheta chincheta-der" aria-hidden="true"><svg width="16" height="24" viewBox="0 0 16 24" xmlns="http://www.w3.org/2000/svg"><circle cx="8" cy="8" r="7" fill="#d94f82"/><circle cx="8" cy="7" r="6" fill="#ff78a6"/><circle cx="5.5" cy="4.5" r="2.5" fill="#ffb3cc" opacity="0.5"/><rect x="7" y="14" width="2" height="10" rx="1" fill="#aaa"/></svg></span>
      <h3 class="text-xl font-semibold text-gray-900 mb-6 flex items-center gap-2">
        <span class="text-[#9E5842]">02.</span> Experiencia
      </h3>
      <ul class="flex flex-col gap-6">
        {experiencia.map(({ empresa, puesto, anio, descripcion }) => (
          <li class="flex gap-4">
            <div class="mt-1 w-2 h-2 rounded-full bg-[#9E5842] shrink-0"></div>
            <div>
              <div class="flex items-center gap-3 flex-wrap">
                <p class="text-gray-900 font-semibold text-sm">{empresa}</p>
                <span class="text-xs text-white bg-[#9E5842] px-2 py-0.5 rounded-full">{anio}</span>
              </div>
              <p class="text-xs text-gray-400 mb-1">{puesto}</p>
              <p class="text-gray-600 text-sm leading-relaxed">{descripcion}</p>
            </div>
          </li>
        ))}
      </ul>
    </div>

    <!-- ── Lenguajes ── -->
    <div class="sm-card-izq relative bg-white rounded-2xl p-8 shadow-sm border border-gray-100 border-t-4 border-t-[#9E5842]">
      <span class="chincheta chincheta-der" aria-hidden="true"><svg width="16" height="24" viewBox="0 0 16 24" xmlns="http://www.w3.org/2000/svg"><circle cx="8" cy="8" r="7" fill="#d94f82"/><circle cx="8" cy="7" r="6" fill="#ff78a6"/><circle cx="5.5" cy="4.5" r="2.5" fill="#ffb3cc" opacity="0.5"/><rect x="7" y="14" width="2" height="10" rx="1" fill="#aaa"/></svg></span>
      <h3 class="text-xl font-semibold text-gray-900 mb-6 flex items-center gap-2">
        <span class="text-[#9E5842]">03.</span> Lenguajes
      </h3>
      <ul class="flex flex-wrap gap-3">
        {lenguajes.map(({ nombre, destacado }) => (
          <li class={`text-sm font-medium px-4 py-2 rounded-lg transition-colors duration-300 border ${
            destacado
              ? 'bg-[#fff0f4] border-[#9E5842] text-[#9E5842]'
              : 'bg-gray-50 border-gray-200 text-gray-700 hover:border-[#9E5842] hover:text-[#9E5842]'
          }`}>
            {nombre}
          </li>
        ))}
      </ul>
    </div>

    <!-- ── Frameworks ── -->
    <div class="sm-card-frameworks relative bg-white rounded-2xl p-8 shadow-sm border border-gray-100 border-t-4 border-t-[#9E5842]">
      <span class="chincheta chincheta-der" aria-hidden="true"><svg width="16" height="24" viewBox="0 0 16 24" xmlns="http://www.w3.org/2000/svg"><circle cx="8" cy="8" r="7" fill="#d94f82"/><circle cx="8" cy="7" r="6" fill="#ff78a6"/><circle cx="5.5" cy="4.5" r="2.5" fill="#ffb3cc" opacity="0.5"/><rect x="7" y="14" width="2" height="10" rx="1" fill="#aaa"/></svg></span>
      <h3 class="text-xl font-semibold text-gray-900 mb-6 flex items-center gap-2">
        <span class="text-[#9E5842]">04.</span> Frameworks
      </h3>
      <ul class="flex flex-wrap gap-3">
        {frameworks.map(({ nombre, destacado }) => (
          <li class={`text-sm font-medium px-4 py-2 rounded-lg transition-colors duration-300 border ${
            destacado
              ? 'bg-[#fff0f4] border-[#9E5842] text-[#9E5842]'
              : 'bg-gray-50 border-gray-200 text-gray-700 hover:border-[#9E5842] hover:text-[#9E5842]'
          }`}>
            {nombre}
          </li>
        ))}
      </ul>
    </div>

    <!-- ── Bases de datos ── -->
    <div class="sm-card-bases relative bg-white rounded-2xl p-8 shadow-sm border border-gray-100 border-t-4 border-t-[#9E5842]">
      <span class="chincheta chincheta-der" aria-hidden="true"><svg width="16" height="24" viewBox="0 0 16 24" xmlns="http://www.w3.org/2000/svg"><circle cx="8" cy="8" r="7" fill="#d94f82"/><circle cx="8" cy="7" r="6" fill="#ff78a6"/><circle cx="5.5" cy="4.5" r="2.5" fill="#ffb3cc" opacity="0.5"/><rect x="7" y="14" width="2" height="10" rx="1" fill="#aaa"/></svg></span>
      <h3 class="text-xl font-semibold text-gray-900 mb-6 flex items-center gap-2">
        <span class="text-[#9E5842]">05.</span> Bases de datos
      </h3>
      <ul class="flex flex-wrap gap-3">
        {basesdedatos.map(({ nombre, destacado }) => (
          <li class={`text-sm font-medium px-4 py-2 rounded-lg transition-colors duration-300 border ${
            destacado
              ? 'bg-[#fff0f4] border-[#9E5842] text-[#9E5842]'
              : 'bg-gray-50 border-gray-200 text-gray-700 hover:border-[#9E5842] hover:text-[#9E5842]'
          }`}>
            {nombre}
          </li>
        ))}
      </ul>
    </div>

    <!-- ── Herramientas ── -->
    <div class="sm-card-herramientas relative bg-white rounded-2xl p-8 shadow-sm border border-gray-100 border-t-4 border-t-[#9E5842]">
      <span class="chincheta chincheta-der" aria-hidden="true"><svg width="16" height="24" viewBox="0 0 16 24" xmlns="http://www.w3.org/2000/svg"><circle cx="8" cy="8" r="7" fill="#d94f82"/><circle cx="8" cy="7" r="6" fill="#ff78a6"/><circle cx="5.5" cy="4.5" r="2.5" fill="#ffb3cc" opacity="0.5"/><rect x="7" y="14" width="2" height="10" rx="1" fill="#aaa"/></svg></span>
      <h3 class="text-xl font-semibold text-gray-900 mb-6 flex items-center gap-2">
        <span class="text-[#9E5842]">06.</span> Herramientas
      </h3>
      <ul class="flex flex-wrap gap-3">
        {herramientas.map(({ nombre, destacado }) => (
          <li class={`text-sm font-medium px-4 py-2 rounded-lg transition-colors duration-300 border ${
            destacado
              ? 'bg-[#fff0f4] border-[#9E5842] text-[#9E5842]'
              : 'bg-gray-50 border-gray-200 text-gray-700 hover:border-[#9E5842] hover:text-[#9E5842]'
          }`}>
            {nombre}
          </li>
        ))}
      </ul>
    </div>

  </div>

  <!-- ── Leyenda ── -->
  <div class="flex items-center gap-6 mt-10 max-w-5xl mx-auto pl-8">
    <span class="flex items-center gap-2 text-sm text-gray-400">
      <span class="inline-block w-4 h-4 rounded bg-[#fff0f4] border border-[#9E5842]"></span>
      Mayor dominio
    </span>
    <span class="flex items-center gap-2 text-sm text-gray-400">
      <span class="inline-block w-4 h-4 rounded bg-gray-50 border border-gray-200"></span>
      Conocimiento funcional
    </span>
  </div>

</section>
<script>
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('sm-visible');
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.1 }
  );

  const selectores = [
    '.sm-titulo',
    '.sm-card-principal',
    '.sm-card-full',
    '.sm-card-izq',
    '.sm-card-frameworks',
    '.sm-card-bases',
    '.sm-card-herramientas',
  ];

  selectores.forEach((sel) => {
    const el = document.querySelector(sel);
    if (el) observer.observe(el);
  });
</script>